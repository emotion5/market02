# 이 파일은 커밋된다. 실제 값은 .env 에 넣는다(.env 는 gitignore).
#
# DATABASE_URL: 앱 런타임 접속 URL. 서버리스(Vercel)면 커넥션 풀러 URL (Neon pooler 등)
# DIRECT_URL  : 마이그레이션·introspection 직결 URL (풀러 우회). 풀러 미사용 시 DATABASE_URL 과 동일.
DATABASE_URL="postgresql://user:password@host:5432/market02?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/market02?schema=public"

# 세션 JWT 서명 키 (긴 랜덤 문자열, 예: openssl rand -base64 32)
SESSION_SECRET="generate-a-long-random-string"
